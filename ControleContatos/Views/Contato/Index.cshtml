@model IEnumerable<ControleContatos.Models.Contato>

@{
    ViewData["Title"] = "Index";

}
@if (TempData["MensagemSucesso"] != null)
{
    <div class="alert alert-success" role="alert"> 
        <button type="button" class="btn btn-danger btn-sm close-alert">X</button> 
        @TempData["MensagemSucesso"]     
    </div>
}
<h1 class="display-4">Listagem de contatos</h1>

<p>
    <a role="button" class="btn btn-primary" asp-action="Create">Novo contato</a>

</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Nome)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Telefone)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Email)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Nome)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Email)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Telefone)
            </td>
            <td>
                    <a role="button" class="btn btn-primary" asp-action="Edit" 
                     asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                     <a role="button" class="btn btn-danger" asp-action="Delete" 
                    asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
